<html>
    <body>
        <h1>Login</h1>
        <form method="POST" action="/user/login">
            <label>Email</label>
            <input type="email" required="true" name="email" />
            <label>Password</label>
            <input type="password" required="true" name="password" />
            <button type="submit">Login</button>
        </form>
    </body>
</html>