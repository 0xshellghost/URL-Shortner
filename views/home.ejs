<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <h1>Hey Welcome to URL Shortner</h1>
    
    <ul>
        <% urls.forEach(url => { %>
            <li>
                <strong><%= url.shortID %></strong> - 
                
                <a href="<%= url.redirectUrl %>" target="_blank">
                    <%= url.redirectUrl %>
                </a>
            </li>
        <% }); %>
    </ul>

</body>
</html>